# Supabase credentials. When these are set the sync worker drains pending
# events to the Supabase backend; when they're missing the app runs fully
# standalone against IndexedDB only.
#
# Copy this file to .env.local and fill in the values from your Supabase
# project settings → API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
